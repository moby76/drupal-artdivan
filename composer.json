{
    "name": "drupal/recommended-project",
    "description": "Project template for Drupal projects with a relocated document root",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "homepage": "https://www.drupal.org/project/drupal",
    "support": {
        "docs": "https://www.drupal.org/docs/user_guide/en/index.html",
        "chat": "https://www.drupal.org/node/314178"
    },
    "repositories": [
        {
            "name": "drupal",
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "packagist": false
        },
        {
            "name": "asset-bootstrap",
            "type": "package",
            "package": {
                "name": "asset/bootstrap",
                "version": "5.3.3",
                "type": "drupal-library",
                "extra": {
                    "installer-name": "bootstrap"
                },
                "dist": {
                    "type": "zip",
                    "url": "https://api.github.com/repos/twbs/bootstrap/zipball/6e1f75f420f68e1d52733b8e407fc7c3766c9dba",
                    "reference": "6e1f75f420f68e1d52733b8e407fc7c3766c9dba"
                }
            }
        },
        {
            "name": "asset-bootstrap-icons",
            "type": "package",
            "package": {
                "name": "asset/bootstrap-icons",
                "version": "1.11.3",
                "type": "drupal-library",
                "extra": {
                    "installer-name": "bootstrap-icons"
                },
                "dist": {
                    "type": "zip",
                    "url": "https://api.github.com/repos/twbs/icons/zipball/8d88686c03c3768a2d82ba4f20c3c4e1b100fa29",
                    "reference": "8d88686c03c3768a2d82ba4f20c3c4e1b100fa29"
                }
            }
        }
    ],
    "require": {
        "asset/bootstrap": "5.3.3",
        "asset/bootstrap-icons": "1.11.3",
        "composer/installers": "^2.0",
        "drupal/address": "^2.0",
        "drupal/admin_toolbar": "^3.6",
        "drupal/auto_entitylabel": "^3.4",
        "drupal/autocomplete_deluxe": "^2.1",
        "drupal/block_field": "^1.0@RC",
        "drupal/bootstrap_layout_builder": "^2.2",
        "drupal/coffee": "^2.0",
        "drupal/conditional_fields": "^4.0@alpha",
        "drupal/conditional_rendering": "^1.0",
        "drupal/core-composer-scaffold": "^11.3.5",
        "drupal/core-project-message": "^11.3.5",
        "drupal/core-recommended": "^11.3.5",
        "drupal/display_builder": "^1.0@beta",
        "drupal/double_field": "^5.0@RC",
        "drupal/entity_clone": "^2.1@beta",
        "drupal/entity_link_display": "^1.0",
        "drupal/entity_save_and_addanother": "^1.0",
        "drupal/entity_type_clone": "^4.0",
        "drupal/exclude_node_title": "^2.0",
        "drupal/field_label": "^1.5",
        "drupal/field_token_value": "^3.1",
        "drupal/gin": "5.0.x-dev@dev",
        "drupal/layout_builder_blocks": "^1.1",
        "drupal/layout_builder_boolean": "^1.0@alpha",
        "drupal/layout_options": "^1.7",
        "drupal/layout_paragraphs": "^3.0@alpha",
        "drupal/logo_image_enhanced": "^1.0",
        "drupal/media_default_image": "^1.0",
        "drupal/media_folders": "^1.0",
        "drupal/nomarkup": "^1.0",
        "drupal/paragraph_group": "^4.0",
        "drupal/paragraphs": "^1.20",
        "drupal/pathauto": "^1.14",
        "drupal/phonenumber": "^1.0@beta",
        "drupal/print_this_page": "^1.0",
        "drupal/project_browser": "^2.1",
        "drupal/serial": "^2.1",
        "drupal/term_reference_tree": "^2.0",
        "drupal/time_range": "^9.0",
        "drupal/token": "^1.17",
        "drupal/ui_icons": "^1.1",
        "drupal/ui_skins": "^1.1@alpha",
        "drupal/ui_suite_bootstrap": "^5.2",
        "drupal/unique_field": "2.x-dev@dev",
        "drupal/unused_modules": "^1.6",
        "drupal/upgrade_status": "^5.0@alpha",
        "drupal/view_mode_page": "^4.0",
        "drupal/views_arg_entity_field": "^3.0@beta",
        "drush/drush": "^13",
        "mikehaertl/phpwkhtmltopdf": "~2.1",
        "tecnickcom/tcpdf": "~6"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "tbachert/spi": true
        },
        "sort-packages": true
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            }
        },
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ],
            "web/modules/custom/{$name}": [
                "type:drupal-custom-module"
            ],
            "web/profiles/custom/{$name}": [
                "type:drupal-custom-profile"
            ],
            "web/themes/custom/{$name}": [
                "type:drupal-custom-theme"
            ]
        },
        "drupal-core-project-message": {
            "include-keys": [
                "homepage",
                "support"
            ],
            "post-create-project-cmd-message": [
                "<bg=blue;fg=white>                                                         </>",
                "<bg=blue;fg=white>  Congratulations, you’ve installed the Drupal codebase  </>",
                "<bg=blue;fg=white>  from the drupal/recommended-project template!          </>",
                "<bg=blue;fg=white>                                                         </>",
                "",
                "<bg=yellow;fg=black>Next steps</>:",
                "  * Install the site: https://www.drupal.org/docs/installing-drupal",
                "  * Read the user guide: https://www.drupal.org/docs/user_guide/en/index.html",
                "  * Get support: https://www.drupal.org/support",
                "  * Get involved with the Drupal community:",
                "      https://www.drupal.org/getting-involved",
                "  * Remove the plugin that prints this message:",
                "      composer remove drupal/core-project-message"
            ]
        }
    },
    "require-dev": {
        "drupal/core-dev": "^11"
    }
}
